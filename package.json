{
  "name": "nexus",
  "private": true,
  "workspaces": [
    "server",
    "worker",
    "db",
    "subscribers/*",
    "client"
  ],
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "migrate:db": "npm run migrate -w db",
    "generate:db": "npm run generate -w db",
    "seed:db": "npm run seed -w db",
    "dev:server": "npm run dev -w server",
    "dev:worker": "npm run dev -w worker",
    "dev:accounting": "npm run dev -w subscribers/accounting",
    "dev:shipping": "npm run dev -w subscribers/shipping",
    "dev:client": "npm run dev -w client",
    "test:worker": "npm run test -w worker",
    "test:server": "npm run test -w server",
    "format:write": "npx prettier --write \"**/*.{js,ts,json,css,md}\"",
    "format:check": "npx prettier --check \"**/*.{js,ts,json,css,md}\"",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:unused-files": "node scripts/check-unused-files.js",
    "lint:all": "npm run lint && npm run lint:unused-files"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
